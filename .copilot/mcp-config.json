{
  "mcpServers": {
    "workiq": {
      "command": "npx",
      "args": [
        "-y",
        "@microsoft/workiq",
        "mcp"
      ]
    },
    "EXAMPLE-trello": {
      "command": "npx",
      "args": [
        "-y",
        "@trello/mcp-server"
      ],
      "env": {
        "TRELLO_API_KEY": "${TRELLO_API_KEY}",
        "TRELLO_TOKEN": "${TRELLO_TOKEN}"
      }
    }
  }
}
